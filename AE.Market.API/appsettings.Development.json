{
  "ConnectionStrings": {
    "Database": "Host=postgres;Port=5432;Database=marketDb;Username=postgres;Password=password;Include Error Detail=true",
    "redis": "redis:6379,password=password,abortConnect=false"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "ServerUrl": "http://seq:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Elasticsearch": {
    "Uri": "http://elasticsearch:9200",
    "DefaultIndex": "products"
  },
  "Jwt": {
    "Secret": "FXRSBWkbM6maMusUKEgFuF634TYgXxSb",
    "Issuer": "AE.Market.API",
    "Audience": "developers",
    "ExpirationInMinutes": 60
  },
  "Cors": {
    "AdminOrigins": ["https://localhost:3000", "http://localhost:3000"],
    "PublicOrigins": ["https://localhost:3001", "http://localhost:3001"],
    "DefaultOrigins": []
  }
}
